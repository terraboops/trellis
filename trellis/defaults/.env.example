# Authentication: uses your Claude Code CLI credentials (~/.claude)
# No API key needed here.

# Telegram (optional -- without these, reviews auto-approve)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Budget defaults (USD)
MAX_BUDGET_IDEATION=0.50
MAX_BUDGET_IMPLEMENTATION=10.00
MAX_BUDGET_VALIDATION=1.00
MAX_BUDGET_RELEASE=3.00
MAX_BUDGET_WATCHER=0.10

# Model tiers
MODEL_TIER_HIGH=claude-sonnet-4-6
MODEL_TIER_LOW=claude-haiku-4-5

# Watcher cadences (cron)
WATCHER_COMPETITIVE_CRON=0 */6 * * *
WATCHER_RESEARCH_CRON=0 8 * * *

# Web
WEB_HOST=0.0.0.0
WEB_PORT=8000
